<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ЖРИСУКА — Самые злые начос в галактике</title>
    <!-- Подключаем жирные гротескные шрифты -->
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Russo+One&display=swap" rel="stylesheet">
    <style>
        :root {
            --violet: #9B00FF;
            --lime: #CFFF00;
            --acid-orange: #FF5E00;
            --black: #0a0a0a;
            --white: #f0f0f0;
            --red: #ff1a1a;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--black);
            color: var(--white);
            font-family: 'Russo One', sans-serif;
            overflow-x: hidden;
            position: relative;
        }

        /* Анимированный фон (дым, вспышки) */
        .background-smoke {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            pointer-events: none;
            background: radial-gradient(circle at 20% 30%, rgba(155, 0, 255, 0.25) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(207, 255, 0, 0.2) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(255, 94, 0, 0.2) 0%, transparent 60%);
            animation: smokePulse 8s infinite alternate ease-in-out;
        }

        .floating-chips {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
            overflow: hidden;
        }

        .chip {
            position: absolute;
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-bottom: 25px solid rgba(255, 255, 255, 0.3);
            filter: drop-shadow(0 0 8px var(--lime));
            animation: floatChip linear infinite;
            transform: rotate(calc(var(--rotate) * 1deg));
        }

        @keyframes floatChip {
            0% {
                transform: translateY(110vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.8;
            }
            90% {
                opacity: 0.6;
            }
            100% {
                transform: translateY(-20vh) rotate(360deg);
                opacity: 0;
            }
        }

        @keyframes smokePulse {
            0% {
                opacity: 0.7;
                transform: scale(1);
            }
            100% {
                opacity: 1;
                transform: scale(1.05);
            }
        }

        /* Шапка */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: rgba(10, 10, 10, 0.92);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 25px;
            z-index: 1000;
            border-bottom: 3px solid var(--violet);
            box-shadow: 0 0 25px rgba(155, 0, 255, 0.5);
        }

        .logo {
            font-family: 'Bangers', cursive;
            font-size: 3rem;
            color: var(--lime);
            letter-spacing: 4px;
            position: relative;
            text-shadow: 4px 4px 0 var(--violet), 6px 6px 0 var(--acid-orange);
            display: flex;
            align-items: center;
            cursor: pointer;
        }

        .logo .mascot-bite {
            display: inline-block;
            position: relative;
            margin-right: -8px;
        }

        .logo .letter-zh {
            position: relative;
            display: inline-block;
        }

        /* Маскот грызёт букву Ж (имитация зубов) */
        .letter-zh::after {
            content: "";
            position: absolute;
            bottom: -6px;
            left: 5px;
            width: 28px;
            height: 16px;
            background: white;
            clip-path: polygon(0% 100%, 20% 20%, 40% 100%, 60% 20%, 80% 100%, 100% 20%);
            background: #fff;
            box-shadow: 0 0 6px var(--acid-orange);
            animation: bite 0.6s infinite alternate;
        }

        @keyframes bite {
            0% {
                transform: translateY(0);
            }
            100% {
                transform: translateY(3px);
            }
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .burger {
            display: flex;
            flex-direction: column;
            gap: 7px;
            cursor: pointer;
            z-index: 1001;
        }

        .burger span {
            width: 36px;
            height: 6px;
            background: var(--lime);
            border-radius: 8px;
            transition: 0.3s;
            box-shadow: 0 0 8px var(--lime);
            clip-path: polygon(0 0, 100% 0, 90% 100%, 10% 100%);
        }

        .burger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 8px);
        }
        .burger.active span:nth-child(2) {
            opacity: 0;
        }
        .burger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -8px);
        }

        /* Бургер-меню панель */
        .menu-panel {
            position: fixed;
            top: 0;
            right: -300px;
            width: 280px;
            height: 100vh;
            background: #111;
            border-left: 3px solid var(--violet);
            padding: 90px 25px;
            transition: right 0.4s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            z-index: 999;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }
        .menu-panel.open {
            right: 0;
        }
        .menu-panel a {
            font-size: 1.8rem;
            color: var(--lime);
            text-decoration: none;
            font-family: 'Bangers', cursive;
            letter-spacing: 2px;
            transition: 0.2s;
        }
        .menu-panel a:hover {
            color: var(--acid-orange);
            text-shadow: 0 0 15px var(--acid-orange);
        }

        .btn-bite {
            background: var(--acid-orange);
            color: #000;
            font-family: 'Bangers', cursive;
            font-size: 1.4rem;
            padding: 8px 20px;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            text-decoration: none;
            transition: 0.3s;
            box-shadow: 0 0 18px var(--acid-orange);
            letter-spacing: 2px;
        }
        .btn-bite:hover {
            background: var(--lime);
            box-shadow: 0 0 28px var(--lime);
            transform: scale(1.1);
        }

        .cart-icon {
            font-size: 2.4rem;
            cursor: pointer;
            position: relative;
            color: var(--lime);
            filter: drop-shadow(0 0 10px var(--violet));
        }
        .cart-count {
            position: absolute;
            top: -10px;
            right: -15px;
            background: var(--acid-orange);
            color: #000;
            border-radius: 50%;
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.9rem;
        }

        /* Hero */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            padding-top: 80px;
        }
        .hero-content {
            z-index: 2;
        }
        .hero h1 {
            font-family: 'Bangers', cursive;
            font-size: 5.5rem;
            color: var(--lime);
            text-shadow: 10px 8px 0 var(--violet), 12px 12px 0 var(--acid-orange);
            line-height: 1;
        }
        .hero p {
            font-size: 1.8rem;
            margin: 20px 0 30px;
            color: #ddd;
        }
        .mascot-hero {
            position: absolute;
            right: 5%;
            bottom: 10%;
            width: 300px;
            height: 300px;
            z-index: 1;
            pointer-events: none;
        }
        /* CSS-маскот (упрощённый) */
        .monster {
            position: relative;
            width: 200px;
            height: 200px;
            background: var(--violet);
            border-radius: 50% 40% 60% 50%;
            box-shadow: 0 0 45px var(--violet);
            animation: monsterDance 2s infinite alternate;
            margin: 0 auto;
        }
        .monster .eye {
            position: absolute;
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 50%;
            box-shadow: inset 0 0 10px black;
        }
        .monster .eye::after {
            content: '';
            position: absolute;
            width: 18px;
            height: 18px;
            background: black;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        .eye-left {
            top: 45px;
            left: 35px;
        }
        .eye-center {
            top: 35px;
            left: 80px;
            width: 55px;
            height: 55px;
        }
        .eye-right {
            top: 50px;
            right: 30px;
        }
        .teeth {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 4px;
        }
        .tooth {
            width: 22px;
            height: 35px;
            background: white;
            border-radius: 5px 5px 10px 10px;
            box-shadow: 0 0 12px white;
        }
        .tongue {
            position: absolute;
            bottom: -25px;
            left: 65px;
            width: 60px;
            height: 60px;
            background: #ff2b75;
            border-radius: 50%;
            animation: tongueLick 0.8s infinite;
        }
        .horns {
            position: absolute;
            top: -35px;
            left: 45px;
            display: flex;
            gap: 80px;
        }
        .horn {
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-bottom: 45px solid var(--acid-orange);
            filter: drop-shadow(0 0 10px var(--acid-orange));
        }
        @keyframes monsterDance {
            0% {
                transform: translateY(0) rotate(-2deg);
            }
            100% {
                transform: translateY(15px) rotate(3deg);
            }
        }
        @keyframes tongueLick {
            0%,
            100% {
                transform: scaleY(1);
            }
            50% {
                transform: scaleY(1.7);
            }
        }

        /* Каталог */
        .catalog {
            padding: 60px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .section-title {
            font-family: 'Bangers', cursive;
            font-size: 3.8rem;
            color: var(--acid-orange);
            text-align: center;
            text-shadow: 5px 5px 0 var(--violet);
            margin-bottom: 30px;
        }
        .filter-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }
        .filter-btn {
            background: #222;
            color: var(--lime);
            border: 2px solid var(--violet);
            padding: 10px 20px;
            font-family: 'Bangers', cursive;
            font-size: 1.3rem;
            cursor: pointer;
            transition: 0.2s;
            border-radius: 20px;
        }
        .filter-btn.active {
            background: var(--violet);
            box-shadow: 0 0 25px var(--violet);
        }
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 35px;
        }
        .product-card {
            background: #111;
            border: 2px solid var(--violet);
            border-radius: 25px;
            padding: 20px;
            text-align: center;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }
        .product-card:hover {
            transform: rotateY(8deg) scale(1.05);
            box-shadow: 0 0 35px var(--violet);
        }
        .product-img {
            width: 100%;
            height: 200px;
            background-size: cover;
            background-position: center;
            border-radius: 15px;
            margin-bottom: 15px;
            transition: 0.4s;
            position: relative;
        }
        /* Заглушки под цвет упаковки */
        .taste-kraken {
            background: linear-gradient(145deg, #1a1a1a, #333);
            border: 3px solid #222;
        }
        .taste-dragon {
            background: linear-gradient(145deg, #1b3b1b, #2f5a2f);
        }
        .taste-troll {
            background: linear-gradient(145deg, #b8520f, #e8791c);
        }
        .taste-mushroom {
            background: linear-gradient(145deg, #9e1e1e, #d62b2b);
        }
        .taste-shark {
            background: linear-gradient(145deg, #1a3b5c, #2a5a8c);
        }
        .taste-alien {
            background: linear-gradient(145deg, #4b1d6e, #7527a8);
        }
        .product-card h3 {
            font-family: 'Bangers', cursive;
            font-size: 1.9rem;
            color: var(--lime);
        }
        .product-card p {
            font-size: 0.9rem;
            margin: 10px 0;
        }
        .btn-cart {
            background: var(--acid-orange);
            border: none;
            padding: 10px 25px;
            font-family: 'Bangers', cursive;
            font-size: 1.2rem;
            cursor: pointer;
            border-radius: 20px;
            margin-top: 10px;
            transition: 0.3s;
        }
        .btn-cart:hover {
            background: var(--lime);
            box-shadow: 0 0 25px var(--lime);
        }

        /* Оптовикам */
        .wholesale {
            background: #0d0d0d;
            padding: 60px 20px;
        }
        .form-wholesale {
            max-width: 500px;
            margin: 30px auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .form-wholesale input,
        .form-wholesale textarea {
            padding: 14px;
            background: #1a1a1a;
            border: 2px solid var(--violet);
            color: white;
            font-family: 'Russo One', sans-serif;
            border-radius: 10px;
        }
        .form-wholesale button {
            background: var(--lime);
            border: none;
            font-family: 'Bangers', cursive;
            font-size: 1.6rem;
            padding: 12px;
            cursor: pointer;
        }

        /* Где купить */
        .map-section {
            padding: 50px 20px;
            text-align: center;
        }
        .map-container {
            margin: 20px auto;
            max-width: 700px;
            border: 4px solid var(--acid-orange);
            border-radius: 20px;
            overflow: hidden;
        }

        /* Футер */
        .footer {
            background: #000;
            padding: 30px;
            text-align: center;
            border-top: 3px solid var(--violet);
        }
        .socials a {
            font-size: 2rem;
            margin: 0 10px;
            color: var(--lime);
            text-decoration: none;
        }

        /* Модалки */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            justify-content: center;
            align-items: center;
            z-index: 2000;
        }
        .modal-content {
            background: #111;
            padding: 30px;
            border: 3px solid var(--violet);
            border-radius: 20px;
            max-width: 450px;
            width: 90%;
            color: white;
        }
        .close {
            float: right;
            font-size: 2rem;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="background-smoke"></div>
    <div class="floating-chips" id="floatingChips"></div>

    <!-- Хедер -->
    <header class="header">
        <div class="logo" onclick="location.href='#hero'">
            <span class="letter-zh">Ж</span>РИСУКА
        </div>
        <div class="header-right">
            <div class="burger" id="burgerBtn">
                <span></span><span></span><span></span>
            </div>
            <a href="#catalog" class="btn-bite">Впиться!</a>
            <div class="cart-icon" id="cartIcon">
                🛒<span class="cart-count" id="cartCount">0</span>
            </div>
        </div>
    </header>

    <!-- Бургер-меню -->
    <div class="menu-panel" id="menuPanel">
        <a href="#hero">Главная</a>
        <a href="#catalog">Каталог</a>
        <a href="#wholesale">Оптовикам</a>
        <a href="#where">Где купить</a>
        <a href="#contacts">Контакты</a>
        <a href="#" id="lkBtn">Личный кабинет</a>
    </div>

    <!-- Главный экран -->
    <section class="hero" id="hero">
        <div class="hero-content">
            <h1>ЖРИСУКА:<br>Хватит это терпеть!</h1>
            <p>Самые злые начос в галактике. Попробуй и взорви себе мозг!</p>
            <a href="#catalog" class="btn-bite" style="font-size:2rem; padding:15px 35px;">Закинуться вкусностями</a>
        </div>
        <div class="mascot-hero">
            <div class="monster">
                <div class="eye eye-left"></div>
                <div class="eye eye-center"></div>
                <div class="eye eye-right"></div>
                <div class="horns"><div class="horn"></div><div class="horn"></div></div>
                <div class="teeth"><div class="tooth"></div><div class="tooth"></div><div class="tooth"></div></div>
                <div class="tongue"></div>
            </div>
        </div>
    </section>

    <!-- Каталог -->
    <section class="catalog" id="catalog">
        <h2 class="section-title">Чё брать будем?</h2>
        <div class="filter-buttons">
            <button class="filter-btn active" data-filter="all">Все</button>
            <button class="filter-btn" data-filter="spicy">Острые</button>
            <button class="filter-btn" data-filter="meat">Мясные</button>
            <button class="filter-btn" data-filter="veggie">Овощные</button>
            <button class="filter-btn" data-filter="concept">Концептуальные</button>
        </div>
        <div class="product-grid" id="productGrid">
            <!-- Карточка 1: Клятва Кракена (мясная) -->
            <div class="product-card" data-category="meat">
                <div class="product-img taste-kraken"></div>
                <h3>Клятва Кракена</h3>
                <p>Черные начос с вкусом кальмара в чернилах каракатицы.</p>
                <button class="btn-cart" data-name="Клятва Кракена">В корзину</button>
            </div>
            <!-- Карточка 2: Сопли Дракона (острая) -->
            <div class="product-card" data-category="spicy">
                <div class="product-img taste-dragon"></div>
                <h3>Сопли Дракона</h3>
                <p>Зелёные начос халапеньо-лайм с взрывной карамелью.</p>
                <button class="btn-cart" data-name="Сопли Дракона">В корзину</button>
            </div>
            <!-- Карточка 3: Сытый Тролль (мясная) -->
            <div class="product-card" data-category="meat">
                <div class="product-img taste-troll"></div>
                <h3>Сытый Тролль</h3>
                <p>Сыр чеддер, пиво и копчёные рёбрышки BBQ.</p>
                <button class="btn-cart" data-name="Сытый Тролль">В корзину</button>
            </div>
            <!-- Карточка 4: Ядерный Гриб (острая) -->
            <div class="product-card" data-category="spicy">
                <div class="product-img taste-mushroom"></div>
                <h3>Ядерный Гриб</h3>
                <p>Жгучий чили, сметана и лесные грибы.</p>
                <button class="btn-cart" data-name="Ядерный Гриб">В корзину</button>
            </div>
            <!-- Карточка 5: Челюсть Акулы (овощная) -->
            <div class="product-card" data-category="veggie">
                <div class="product-img taste-shark"></div>
                <h3>Челюсть Акулы</h3>
                <p>Голубой сыр Дор-Блю и сельдерей.</p>
                <button class="btn-cart" data-name="Челюсть Акулы">В корзину</button>
            </div>
            <!-- Карточка 6: Плевок Инопланетянина (концепт) -->
            <div class="product-card" data-category="concept">
                <div class="product-img taste-alien"></div>
                <h3>Плевок Инопланетянина</h3>
                <p>Виноград, чёрная смородина и острейший перец.</p>
                <button class="btn-cart" data-name="Плевок Инопланетянина">В корзину</button>
            </div>
        </div>
    </section>

    <!-- Оптовикам -->
    <section class="wholesale" id="wholesale">
        <h2 class="section-title">Хочешь продавать ЖРИСУКУ у себя? Жадно?</h2>
        <p style="text-align:center;">Стань дилером бездны. Отгрузки от 1 коробки. Мурино ждет!</p>
        <form class="form-wholesale" id="wholesaleForm">
            <input type="text" placeholder="Название компании" required>
            <input type="text" placeholder="ИНН" required>
            <input type="text" placeholder="Город" required>
            <input type="text" placeholder="Контактное лицо" required>
            <input type="tel" placeholder="Телефон" required>
            <input type="email" placeholder="Email" required>
            <textarea placeholder="Комментарий"></textarea>
            <button type="submit">Стать партнером</button>
        </form>
        <p style="text-align:center; margin-top:15px;"><a href="#" style="color:var(--lime);">Скачать рекламные материалы и прайс (.pdf)</a></p>
    </section>

    <!-- Где купить -->
    <section class="map-section" id="where">
        <h2 class="section-title">Наше логово</h2>
        <div class="map-container">
            <iframe src="https://yandex.ru/map-widget/v1/?ll=30.3158%2C59.9386&z=12&pt=30.3158,59.9386,pm2rdl&l=map" width="100%" height="350" frameborder="0"></iframe>
        </div>
        <p style="margin-top:20px;">Приезжай в гости в Мурино, обсудим опт или просто пожрем. Шоу-рум с дегустацией!</p>
    </section>

    <!-- Футер -->
    <footer class="footer" id="contacts">
        <div>ЖРИСУКА © 2026. Все права защищены, а зубы сломаны. 18+</div>
        <div class="socials">
            <a href="#">🦷</a> <a href="#">🦷</a>
        </div>
        <div><a href="#" style="color:gray;">Политика конфиденциальности</a> | <a href="#" style="color:gray;">Оферта</a></div>
    </footer>

    <!-- Модалка корзины -->
    <div class="modal" id="cartModal">
        <div class="modal-content">
            <span class="close" id="closeCart">&times;</span>
            <h2 style="font-family:Bangers; color:var(--lime);">Твоя пасть не пуста</h2>
            <ul id="cartItems" style="list-style:none; padding:0;"></ul>
            <p><strong>Итого: <span id="cartTotal">0</span> ₽</strong></p>
            <input type="text" placeholder="Промокод" style="width:100%; padding:10px; margin:5px 0; background:#1a1a1a; border:1px solid var(--violet); color:white;">
            <button class="btn-cart" style="width:100%;">ЖРАААТЬ!</button>
        </div>
    </div>

    <!-- Модалка ЛК -->
    <div class="modal" id="lkModal">
        <div class="modal-content">
            <span class="close" id="closeLk">&times;</span>
            <h2 style="font-family:Bangers; color:var(--acid-orange);">Личный кабинет</h2>
            <p>Мои заказы: пока пусто, слабак.</p>
            <p>Профиль: Имя, телефон, адрес.</p>
            <p>🦷 Накопленные зубы: <strong>12</strong> (100 зубов = скидка 10%)</p>
        </div>
    </div>

    <script>
        // Плавающие чипсы на фоне
        const chipsContainer = document.getElementById('floatingChips');
        for (let i = 0; i < 18; i++) {
            const chip = document.createElement('div');
            chip.className = 'chip';
            chip.style.left = Math.random() * 100 + '%';
            chip.style.animationDuration = (Math.random() * 8 + 6) + 's';
            chip.style.animationDelay = Math.random() * 5 + 's';
            chip.style.setProperty('--rotate', Math.random() * 360);
            chipsContainer.appendChild(chip);
        }

        // Бургер-меню
        const burgerBtn = document.getElementById('burgerBtn');
        const menuPanel = document.getElementById('menuPanel');
        burgerBtn.addEventListener('click', () => {
            burgerBtn.classList.toggle('active');
            menuPanel.classList.toggle('open');
        });
        // Закрытие меню при клике на ссылку
        document.querySelectorAll('.menu-panel a').forEach(link => {
            link.addEventListener('click', () => {
                burgerBtn.classList.remove('active');
                menuPanel.classList.remove('open');
            });
        });

        // Фильтр каталога
        const filterBtns = document.querySelectorAll('.filter-btn');
        const productCards = document.querySelectorAll('.product-card');
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const filterValue = btn.dataset.filter;
                productCards.forEach(card => {
                    if (filterValue === 'all' || card.dataset.category === filterValue) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });

        // Корзина
        let cart = [];
        const cartCountSpan = document.getElementById('cartCount');
        const cartIcon = document.getElementById('cartIcon');
        const cartModal = document.getElementById('cartModal');
        const closeCart = document.getElementById('closeCart');
        const cartItemsList = document.getElementById('cartItems');
        const cartTotalSpan = document.getElementById('cartTotal');

        function updateCartUI() {
            cartCountSpan.textContent = cart.length;
            cartItemsList.innerHTML = '';
            let total = 0;
            cart.forEach((item, index) => {
                const li = document.createElement('li');
                li.textContent = `${item.name} - 100 г (150 ₽) `;
                const removeBtn = document.createElement('button');
                removeBtn.textContent = 'Удалить';
                removeBtn.style.marginLeft = '10px';
                removeBtn.onclick = () => { cart.splice(index,1); updateCartUI(); };
                li.appendChild(removeBtn);
                cartItemsList.appendChild(li);
                total += 150;
            });
            cartTotalSpan.textContent = total;
        }

        document.querySelectorAll('.btn-cart').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const name = e.target.dataset.name;
                cart.push({ name, price: 150 });
                updateCartUI();
                // Анимация маскота в корзине
                cartIcon.style.transform = 'scale(1.3)';
                setTimeout(() => cartIcon.style.transform = 'scale(1)', 200);
            });
        });

        cartIcon.addEventListener('click', () => cartModal.style.display = 'flex');
        closeCart.addEventListener('click', () => cartModal.style.display = 'none');
        window.addEventListener('click', (e) => {
            if (e.target === cartModal) cartModal.style.display = 'none';
        });

        // Личный кабинет
        const lkModal = document.getElementById('lkModal');
        const lkBtn = document.getElementById('lkBtn');
        const closeLk = document.getElementById('closeLk');
        lkBtn.addEventListener('click', (e) => {
            e.preventDefault();
            lkModal.style.display = 'flex';
        });
        closeLk.addEventListener('click', () => lkModal.style.display = 'none');
        window.addEventListener('click', (e) => {
            if (e.target === lkModal) lkModal.style.display = 'none';
        });

        // Форма оптовиков (заглушка)
        document.getElementById('wholesaleForm').addEventListener('submit', (e) => {
            e.preventDefault();
            alert('Заявка отправлена! Скоро свяжемся, зубастик.');
        });
    </script>
</body>
</html>
